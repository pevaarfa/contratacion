/* ══ TABS ═══════════════════════════════════════════════════════════════ */
function switchTab(tab){
  document.getElementById('tabDraw').classList.toggle('on',tab==='draw');
  document.getElementById('tabUp').classList.toggle('on',tab==='upload');
  document.getElementById('panelDraw').style.display=tab==='draw'?'block':'none';
  document.getElementById('panelUp').style.display=tab==='upload'?'block':'none';
  firmaB64=null;btnF.disabled=true;
  document.getElementById('ctBody').innerHTML=renderContrato(null);
  if(tab==='draw'){setTimeout(initCanvas,50);}
}
/* ══ CANVAS ══════════════════════════════════════════════════════════════ */
var canvas=document.getElementById('sigCanvas');
var ctx=canvas.getContext('2d');
var drawing=false;var hasDrawn=false;
function resizeCanvas(){
  var r=canvas.getBoundingClientRect();var s=window.devicePixelRatio||1;
  canvas.width=r.width*s;canvas.height=180*s;ctx.scale(s,s);
  ctx.strokeStyle='#0f2d5a';ctx.lineWidth=2.5;ctx.lineCap='round';ctx.lineJoin='round';
}
/* Canvas se inicializa cuando el panel es visible */
function initCanvas(){
  var r=canvas.getBoundingClientRect();
  if(r.width===0){setTimeout(initCanvas,50);return;}
  var s=window.devicePixelRatio||1;
  canvas.width=r.width*s;canvas.height=180*s;ctx.scale(s,s);
  ctx.strokeStyle='#0f2d5a';ctx.lineWidth=2.5;ctx.lineCap='round';ctx.lineJoin='round';
}
window.addEventListener('resize',function(){if(!hasDrawn)initCanvas();});
function getPos(e,c){var r=c.getBoundingClientRect();var t=e.touches?e.touches[0]:e;return{x:t.clientX-r.left,y:t.clientY-r.top};}
function startDraw(e){e.preventDefault();drawing=true;var p=getPos(e,canvas);ctx.beginPath();ctx.moveTo(p.x,p.y);}
function doDraw(e){e.preventDefault();if(!drawing)return;hasDrawn=true;var p=getPos(e,canvas);ctx.lineTo(p.x,p.y);ctx.stroke();updateCanvasFirma();}
function endDraw(e){e.preventDefault();drawing=false;}
canvas.addEventListener('mousedown',startDraw);canvas.addEventListener('mousemove',doDraw);canvas.addEventListener('mouseup',endDraw);
canvas.addEventListener('touchstart',startDraw,{passive:false});canvas.addEventListener('touchmove',doDraw,{passive:false});canvas.addEventListener('touchend',endDraw,{passive:false});
function clearCanvas(){ctx.clearRect(0,0,canvas.width,canvas.height);hasDrawn=false;firmaB64=null;btnF.disabled=true;document.getElementById('ctBody').innerHTML=renderContrato(null);}
function updateCanvasFirma(){firmaB64=canvas.toDataURL('image/png');btnF.disabled=false;document.getElementById('ctBody').innerHTML=renderContrato(firmaB64);}
/* ══ UPLOAD ══════════════════════════════════════════════════════════════ */
var firmaB64=null;
var fileIn=document.getElementById('fileIn');
var upZone=document.getElementById('upZone');
var prevZone=document.getElementById('prevZone');
var prevImg=document.getElementById('prevImg');
var btnF=document.getElementById('btnFirmar');
function cargar(file){
  if(!file)return;if(file.size>5*1024*1024){alert('Imagen muy grande. Maximo 5MB.');return;}
  var reader=new FileReader();
  reader.onload=function(e){firmaB64=e.target.result;prevImg.src=firmaB64;upZone.style.display='none';prevZone.style.display='block';btnF.disabled=false;document.getElementById('ctBody').innerHTML=renderContrato(firmaB64);};
  reader.readAsDataURL(file);
}
fileIn.addEventListener('change',function(e){cargar(e.target.files[0]);});
upZone.addEventListener('dragover',function(e){e.preventDefault();upZone.classList.add('drag');});
upZone.addEventListener('dragleave',function(){upZone.classList.remove('drag');});
upZone.addEventListener('drop',function(e){e.preventDefault();upZone.classList.remove('drag');cargar(e.dataTransfer.files[0]);});
document.getElementById('btnCambiar').addEventListener('click',function(){firmaB64=null;btnF.disabled=true;prevZone.style.display='none';upZone.style.display='block';fileIn.value='';document.getElementById('ctBody').innerHTML=renderContrato(null);});
btnF.addEventListener('click',async function(){
  if(!firmaB64)return;
  if(sessionStorage.getItem(CLAVE)||localStorage.getItem(CLAVE)){document.getElementById('sigCard').style.display='none';document.getElementById('dupCard').style.display='block';return;}
  document.getElementById('btnTxt').style.display='none';document.getElementById('btnSpin').style.display='flex';this.disabled=true;
  var payload={token:token,firma:firmaB64,ts:new Date().toISOString(),nombre:nombre,cedula:cedula,cargo:cargo,tipo:tipo,email:emailV,salario:salario,periodo:periodo,fecha:fecha,labor:labor,ciudad:ciudad,telefono:telefono};
  try{
    await fetch(WEBHOOK,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    try{sessionStorage.setItem(CLAVE,'1');}catch(e){}try{localStorage.setItem(CLAVE,'1');}catch(e){}
    document.getElementById('ctCard').style.display='none';document.getElementById('sigCard').style.display='none';document.getElementById('okCard').style.display='block';
    window.scrollTo({top:0,behavior:'smooth'});
  }catch(e){
    alert('Error al enviar la firma. Verifica tu conexion.');
    document.getElementById('btnTxt').style.display='flex';document.getElementById('btnSpin').style.display='none';this.disabled=false;
  }
});
</script>
